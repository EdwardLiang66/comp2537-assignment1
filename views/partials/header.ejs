<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
  </head>
  <body class="d-flex min-vh-100 flex-column bg-body-tertiary">
    <header>
      <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
        <div class="container">
          <a class="navbar-brand fw-semibold" href="/">Assignment 2</a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
              <li class="nav-item">
                <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">Home</a>
              </li>
              <% if (currentUser) { %>
                <li class="nav-item">
                  <a class="nav-link <%= currentPath === '/members' ? 'active' : '' %>" href="/members">Members</a>
                </li>
                <li class="nav-item">
                  <a class="nav-link <%= currentPath === '/admin' ? 'active' : '' %>" href="/admin">Admin</a>
                </li>
                <li class="nav-item">
                  <a class="btn btn-outline-light btn-sm" href="/logout">Sign out</a>
                </li>
              <% } else { %>
                <li class="nav-item">
                  <a class="nav-link <%= currentPath === '/signup' ? 'active' : '' %>" href="/signup">Sign up</a>
                </li>
                <li class="nav-item">
                  <a class="btn btn-primary btn-sm" href="/login">Log in</a>
                </li>
              <% } %>
            </ul>
          </div>
        </div>
      </nav>
    </header>
    <main class="flex-grow-1 py-5">
      <div class="container">
